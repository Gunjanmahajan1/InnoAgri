# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# Copy these values from your Firebase service-account JSON file.
# Firebase Console → Project Settings → Service Accounts → Generate new private key

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id

# IMPORTANT: The private key has newlines in it.
# Paste the whole key (including -----BEGIN/END PRIVATE KEY-----) exactly as-is.
# The app will automatically convert \n escape sequences.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=000000000000000000000

# ─── AI Advisory ─────────────────────────────────────────────────────────────
AI_ENABLED=false
AI_API_KEY=your_openai_or_gemini_key_here
